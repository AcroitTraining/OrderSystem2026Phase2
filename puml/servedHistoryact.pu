@startuml

title Phase2 提供済み履歴画面

start

repeat:提供済み履歴画面を表示;

switch (ユーザーがボタンを押下)

case ( 戻るボタン)

    if ( ポップアップボタン) then (はい)
        :注文状態を未提供に変更;
    else (いいえ)
    endif


case (\n 注文管理ボタン)
    :注文管理画面へ遷移;
    stop

case ( 編集ボタン)
    :編集画面へ遷移;
    stop

case ( ホームボタン)
    :ホーム画面へ遷移;
    stop

endswitch

@enduml